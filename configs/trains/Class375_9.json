{
  "layout": "UK_MU_01",
  "mappings": [
    {
      "id": "speed_readout",
      "label": "Speed (tenths of kph via Pitch Bend)",
      "control_type": "Label",
      "active": true,
      "api_read_path": "CurrentDrivableActor.Function.HUD_GetSpeed",
      "direction": "api_to_midi",
      "midi_type": "pitchbend",
      "midi_channel": 1,
      "scaling": "m_s_to_tenths_kph",
      "poll": true
    },
    {
