      "api_max": 8,
      "direction": "bidirectional",
      "midi_type": "cc",
      "midi_channel": 1,
      "midi_number": 1,
      "scaling": "notch_lookup",
      "notch_values": [1.00, 0.94, 0.89, 0.78, 0.51, 0.27, 0.21, 0.13, 0.00],
      "poll": true
    },
    {
      "id": "reverser",
